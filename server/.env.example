# Copy this file to server/.env and fill in real values.
# server/.env is git-ignored — never commit real secrets.

PORT=4000

# MongoDB connection string (used from Phase 3).
# Local:  mongodb://localhost:27017/chemdex
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/chemdex
MONGODB_URI=mongodb://localhost:27017/chemdex

# Secret for signing JWT auth tokens — use a long random string.
JWT_SECRET=replace-with-a-long-random-secret-string
